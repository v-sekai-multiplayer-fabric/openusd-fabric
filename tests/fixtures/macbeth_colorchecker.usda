    # Materials are kept primarily for renderers that prefer
    # UsdPreviewSurface bindings; the per-cube primvars:displayColor is
    # what Blender's importer actually picks up, since Blender's
    # behaviour on UsdShade graphs is partial.
    def Scope "Mats"
    {
        def Material "M_dark_skin" {
            token outputs:surface.connect = </Chart/Mats/M_dark_skin/Surface.outputs:surface>
            def Shader "Surface" {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.451, 0.322, 0.267)
                token outputs:surface
            }
        }
        def Material "M_light_skin" {
            token outputs:surface.connect = </Chart/Mats/M_light_skin/Surface.outputs:surface>
            def Shader "Surface" {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.761, 0.588, 0.510)
                token outputs:surface
            }
        }
        def Material "M_blue_sky" {
            token outputs:surface.connect = </Chart/Mats/M_blue_sky/Surface.outputs:surface>
            def Shader "Surface" {

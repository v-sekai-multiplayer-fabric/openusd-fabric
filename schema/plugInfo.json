{
    "_comment_license": "Copyright 2026 The openusd-fabric authors. SPDX-License-Identifier: MIT.",
    "_comment_purpose": "Registers the V-Sekai codeless USD plugin so VSekaiMToonAPI / VSekaiSpringBoneAPI / VSekaiSpringBoneColliderAPI resolve at runtime. Drop this directory on PXR_PLUGINPATH_NAME before any UsdStage::Open call (see blender/post_export_hook.py and idtx-flow's GDExtension entry point).",

    "Plugins": [
        {
            "Name": "vSekaiUsd",
            "Type": "resource",
            "Info": {
                "UsdSchemas": {
                    "schemaPath": "./v_sekai_schema.usda"
                },
                "Types": {
                    "VSekaiMToonAPI": {
                        "bases": ["UsdAPISchemaBase"],
                        "alias": { "UsdSchemaBase": "VSekaiMToonAPI" },
                        "apiSchemaType": "singleApply",
                        "schemaKind": "singleApplyAPI",
                        "schemaIdentifier": "VSekaiMToonAPI"
                    },
                    "VSekaiSpringBoneAPI": {
                        "bases": ["UsdAPISchemaBase"],
                        "alias": { "UsdSchemaBase": "VSekaiSpringBoneAPI" },
                        "apiSchemaType": "singleApply",
                        "schemaKind": "singleApplyAPI",
                        "schemaIdentifier": "VSekaiSpringBoneAPI"
                    },
                    "VSekaiSpringBoneColliderAPI": {
                        "bases": ["UsdAPISchemaBase"],
                        "alias": { "UsdSchemaBase": "VSekaiSpringBoneColliderAPI" },
                        "apiSchemaType": "singleApply",
                        "schemaKind": "singleApplyAPI",
                        "schemaIdentifier": "VSekaiSpringBoneColliderAPI"
                    }
                }
            }
        }
    ]
}
